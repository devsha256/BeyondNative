{
  "info": {
    "_postman_id": "0aa8b6ab-604b-4318-8f92-1de742495e20",
    "name": "boomi-atomsphere",
    "description": "Enterprise API collection for Boomi AtomSphere Platform operations, featuring automated request chaining and metadata extraction.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
